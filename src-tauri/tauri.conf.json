{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LessCommerce Print Agent",
  "version": "0.2.0",
  "identifier": "io.lesscommerce.print-agent",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LessCommerce Print Agent",
        "width": 520,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-idle.png",
      "iconAsTemplate": false,
      "tooltip": "LessCommerce Print Agent",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Desktop print agent for LessCommerce",
    "longDescription": "Polls the LessCommerce API for label print jobs and sends them to a local label printer. Configure once, leave running in the system tray.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "wix": {
        "language": ["en-US", "pl-PL"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["lesscommerce-print-agent"]
      }
    }
  }
}
