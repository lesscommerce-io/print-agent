{
  "name": "lesscommerce-print-agent",
  "version": "0.1.0",
  "description": "Desktop print agent for LessCommerce label printing — polls for jobs, sends them to a local label printer.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "bin": {
    "lesscommerce-print-agent": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts run",
    "setup": "bun run src/index.ts setup",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=dist/lesscommerce-print-agent-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile=dist/lesscommerce-print-agent-linux-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=dist/lesscommerce-print-agent-darwin-x64",
    "build:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=dist/lesscommerce-print-agent-darwin-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=dist/lesscommerce-print-agent-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.9.3"
  }
}
